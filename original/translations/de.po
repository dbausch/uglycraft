#: ugli_2:skeys1
msgid "\342\206\220 = left  \342\206\223 = down  \342\206\222 = right  \342\206\221 = up"
msgstr "← = links  ↓ = unten  → = rechts  ↑ = oben"

#: ugli_2:skeys2
msgid "<F1> = Help  <F2> = Story of UGLI  <F3> = Buy life  <F4> = Restart"
msgstr "<F1> = Hilfe  <F2> = Geschichte von UGLI  <F3> = Leben kaufen  <F4> = Neustart"

