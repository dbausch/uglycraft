msgid "Could not create high score file."
msgstr "Datei UGLI.HSC konnte nicht erzeugt werden."

#: ugli_2:sintrobrand
msgid "* DANISOFT * PRESENTS *"
msgstr "* DANISOFT * PRÄSENTIERT *"

#: ugli_2:sintrowelcome
msgid "Hello, get ready to play!"
msgstr "Hallo, gleich geht's los!"

#: ugli_2:scliusage
msgid "Usage: UGLI_2 [options]"
msgstr "Verwendung: UGLI_2 [Optionen]"

#: ugli_2:sclioptions
msgid "Options:"
msgstr "Optionen:"

#: ugli_2:sclihelp
msgid "Show this help and exit."
msgstr "Diese Hilfe anzeigen und beenden."

#: ugli_2:sclilog1
msgid "Write a structured log (timestamp, version, flags, game events) to <file>."
msgstr "Strukturiertes Protokoll (Zeitstempel, Version, Optionen, Spielereignisse) in <Datei> schreiben."

#: ugli_2:sclilog2
msgid "Library diagnostic messages (ALSA/PortAudio) are also routed there."
msgstr "Bibliotheks-Diagnosemeldungen (ALSA/PortAudio) werden ebenfalls dorthin geleitet."

#: ugli_2:scliskipintro
msgid "Skip the animated intro; still shows the item-descriptions screen."
msgstr "Animiertes Intro überspringen; Gegenstandsliste wird noch angezeigt."

#: ugli_2:sclilevell1
msgid "Start directly at level N (1–9), skipping intro and item-descriptions screen."
msgstr "Direkt bei Level N starten (1–9), Intro und Gegenstandsliste werden übersprungen."

#: ugli_2:sclidump1
msgid "Record every WBFlush write to <file> for rendering-artefact bisection."
msgstr "Jeden WBFlush-Schreibvorgang für Darstellungsfehler-Bisektierung in <Datei> aufzeichnen."

#: ugli_2:sclidump2
msgid "Recording starts immediately; red ● appears at bottom-right while active."
msgstr "Aufzeichnung beginnt sofort; rotes ● erscheint unten rechts solange sie aktiv ist."
