msgstr "G E W O N N E N"

#: ugli_2:sremoveblocks
msgid "R E M O V E   B L O C K S"
msgstr "B L Ö C K E   E N T F E R N E N"

#: ugli_2:splayagain
msgid "P L A Y   A G A I N ?"
msgstr "N O C H M A L  S P I E L E N"

#: ugli_2:syesno
msgid "Y / N"
msgstr "J / N"

#: ugli_2:sfirstname
msgid "FIRST NAME "
msgstr "VORNAME "

#: ugli_2:slastname
