#: ugli_2:skeys1
msgid "\342\206\220 = left  \342\206\223 = down  \342\206\222 = right  \342\206\221 = up"
msgstr "← = links  ↓ = unten  → = rechts  ↑ = oben"

#: ugli_2:skeys2
msgid "<F1> = Help  <F2> = History of UGLI  <F3> = Buy life  <F4> = Restart"
msgstr "<F1> = Hilfe  <F2> = Geschichte von UGLI  <F3> = Leben kaufen  <F4> = Neustart"

#: ugli_2:skeys3
msgid "<P> = Pause  <End> = Slower  <Home> = Faster  <Esc> = Quit"
msgstr "<P> = Pause  <Ende> = Langsamer  <Pos1> = Schneller  <Esc> = Ende"

#: ugli_2:shelptitle
msgid "UGLI HELP"
msgstr "HILFE VON UGLI"

#: ugli_2:shelparrows
msgid "[←/↓/→/↑]   Change direction"
msgstr "[←/↓/→/↑]   Richtung ändern"

#: ugli_2:shelpspace
msgid "[Space]     Toggle block placement (on/off, costs 20 pts each)"
msgstr "[Space]     Blöcke legen umschalten (an/aus, kostet je 20 Punkte)"

#: ugli_2:shelpp
msgid "[P]         Pause a short while (uses 1 pause)"
msgstr "[P]         Kurz pausieren (1 Pause weniger)"

#: ugli_2:shelpesc
msgid "[Esc]       Quit"
msgstr "[Esc]       Abbruch"

#: ugli_2:shelpf1
msgid "[F1]        This help screen"
msgstr "[F1]        Diese Hilfe"

#: ugli_2:shelpf2
msgid "[F2]        The history of UGLI"
msgstr "[F2]        Die Geschichte von UGLI"

#: ugli_2:shelpf3
msgid "[F3]        Buy a life (costs 5000 points)"
msgstr "[F3]        Leben kaufen (kostet 5000 Punkte)"

#: ugli_2:shelpf4
msgid "[F4]        Restart"
msgstr "[F4]        Neustart"

#: ugli_2:shelpf5
msgid "[F5]        Remove all placed blocks"
msgstr "[F5]        Alle gesetzten Blöcke entfernen"

#: ugli_2:shelpend
msgid "[End]       Slower"
msgstr "[Ende]      Langsamer"

#: ugli_2:shelphome
msgid "[Home]      Faster"
msgstr "[Pos1]      Schneller"

#: ugli_2:sstorytitle
msgid "The History of UGLI"
msgstr "Die Geschichte von UGLI"

#: ugli_2:shistorymissing
msgid "File not found."
msgstr "Datei nicht gefunden."

#: ugli_2:sitemlisttitle
msgid "T R E A S U R E S   T O   C O L L E C T"
msgstr "L I S T E   D E R   E I N Z U S A M M E L N D E N   S C H Ä T Z E"

#: ugli_2:siteminsttitle
msgid "H O W   T O   P L A Y"
msgstr "S P I E L A N L E I T U N G"

#: ugli_2:siteminsttext
msgid "Press a key, then press one of the arrow keys. Use the arrow keys to collect the treasures shown above. (The crown comes last.) During the game, press <F1> to see the other keys available during play."
msgstr "Du drückst jetzt eine Taste, dann drückst du eine der Richtungstasten. Danach musst du mit den Richtungstasten die oben gezeigten Dinge einsammeln. (Die Krone kommt ganz zum Schluss.) Während des Spiels kann man mit <F1> die anderen Tasten nachlesen, die zum Bedienen des Spiels zur Verfügung stehen."

#: ugli_2:spresskey
msgid "P R E S S   A N Y   K E Y"
msgstr "T A S T E   D R Ü C K E N"

